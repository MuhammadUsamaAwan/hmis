{
  "name": "@app/api",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "bun run --watch src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts",
    "db:reset": "./scripts/clean-db.sh && bun db:migrate && bun db:seed",
    "test": "NODE_ENV=test bun test --preload ./src/setup-tests.ts"
  },
  "dependencies": {
    "@app/validations": "workspace:*",
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@intlify/elysia": "^2.1.2",
    "bullmq": "^5.74.1",
    "elysia": "^1.4.28",
    "elysia-helmet": "^3.1.0",
    "elysia-ip": "^1.0.10",
    "ioredis": "^5.10.1",
    "rate-limiter-flexible": "^11.0.1",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@elysiajs/eden": "^1.4.9",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "pg": "^8.20.0"
  }
}
